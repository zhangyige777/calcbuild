---
import { SITE_URL } from '../../utils/constants';
import type { CalculatorData } from '../../utils/types';

interface Props {
  data: CalculatorData;
}

const { data } = Astro.props;
const categorySlug = data.category;
const categoryName = categorySlug.replace(/-calculators$/, '').replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
---

<!-- WebApplication Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": data.title,
  "url": `${SITE_URL}/${data.category}/${data.slug}/`,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": data.description
})} />

<!-- BreadcrumbList Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": SITE_URL + "/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": categoryName,
      "item": `${SITE_URL}/${categorySlug}/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": data.title,
      "item": `${SITE_URL}/${data.category}/${data.slug}/`
    }
  ]
})} />

<!-- FAQPage Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": data.faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
})} />

<!-- HowTo Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Calculate ${data.title.replace(' Calculator', '')}`,
  "step": data.formula.steps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "text": step.replace(/^\d+\.\s*/, '')
  }))
})} />
