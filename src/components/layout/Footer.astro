---
import { SITE_NAME, CATEGORIES } from '../../utils/constants';
const year = new Date().getFullYear();
---

<footer class="border-t border-grey-400 bg-white mt-[30px] dark:bg-grey-950 dark:border-grey-850">
  <!-- Brand -->
  <div class="flex items-center justify-center py-[30px] border-b border-grey-300 dark:border-grey-700">
    <a href="/" class="flex items-center gap-[10px] group">
      <svg class="h-[35px] text-brand-700 dark:text-brand-600" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="2" width="36" height="36" rx="8" stroke="currentColor" stroke-width="3"/>
        <rect x="8" y="8" width="10" height="10" rx="2" fill="currentColor"/>
        <rect x="22" y="8" width="10" height="10" rx="2" fill="currentColor" opacity="0.5"/>
        <rect x="8" y="22" width="10" height="10" rx="2" fill="currentColor" opacity="0.5"/>
        <rect x="22" y="22" width="10" height="10" rx="2" fill="currentColor"/>
      </svg>
      <span class="text-[3.0rem] font-bold uppercase text-grey-800 dark:text-grey-100 group-hover:text-brand-700 dark:group-hover:text-brand-600 transition-colors">{SITE_NAME}</span>
    </a>
  </div>

  <!-- Primary Content -->
  <div class="max-w-ic-footer mx-auto px-[20px] py-[30px]">
    <div class="flex flex-wrap justify-around gap-[30px]">
      <!-- Calculators column -->
      <div class="text-left">
        <h2 class="text-[2.6rem] font-medium text-grey-800 dark:text-grey-100 mt-[20px] mb-[30px]">Calculators</h2>
        <ul>
          {CATEGORIES.slice(0, 6).map((cat) => (
            <li class="mb-[15px]">
              <a href={`/${cat.slug}/`} class="text-[1.6rem] font-semibold text-grey-800 dark:text-grey-200 hover:text-brand-700 dark:hover:text-brand-600 transition-colors">{cat.name} Calculators</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More column -->
      <div class="text-left">
        <h2 class="text-[2.6rem] font-medium text-grey-800 dark:text-grey-100 mt-[20px] mb-[30px]">More</h2>
        <ul>
          {CATEGORIES.slice(6).map((cat) => (
            <li class="mb-[15px]">
              <a href={`/${cat.slug}/`} class="text-[1.6rem] font-semibold text-grey-800 dark:text-grey-200 hover:text-brand-700 dark:hover:text-brand-600 transition-colors">{cat.name} Calculators</a>
            </li>
          ))}
          <li class="mb-[15px]">
            <a href="/blog/" class="text-[1.6rem] font-semibold text-grey-800 dark:text-grey-200 hover:text-brand-700 dark:hover:text-brand-600 transition-colors">Blog</a>
          </li>
        </ul>
      </div>

      <!-- Company column -->
      <div class="text-left">
        <h2 class="text-[2.6rem] font-medium text-grey-800 dark:text-grey-100 mt-[20px] mb-[30px]">Company</h2>
        <ul>
          <li class="mb-[15px]">
            <a href="/about/" class="text-[1.6rem] font-semibold text-grey-800 dark:text-grey-200 hover:text-brand-700 dark:hover:text-brand-600 transition-colors">About Us</a>
          </li>
          <li class="mb-[15px]">
            <a href="/contact/" class="text-[1.6rem] font-semibold text-grey-800 dark:text-grey-200 hover:text-brand-700 dark:hover:text-brand-600 transition-colors">Contact Us</a>
          </li>
          <li class="mb-[15px]">
            <a href="/privacy-policy/" class="text-[1.6rem] font-semibold text-grey-800 dark:text-grey-200 hover:text-brand-700 dark:hover:text-brand-600 transition-colors">Privacy Policy</a>
          </li>
          <li class="mb-[15px]">
            <a href="/terms-of-service/" class="text-[1.6rem] font-semibold text-grey-800 dark:text-grey-200 hover:text-brand-700 dark:hover:text-brand-600 transition-colors">Terms of Use</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-[5px] mt-[30px] py-[20px]">
      <!-- Facebook -->
      <a href="#" class="text-grey-800 hover:text-brand-700 dark:text-[#D4D4D4] dark:hover:text-brand-600 transition-colors" aria-label="Facebook">
        <svg class="w-[35px] h-[35px]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <!-- Instagram -->
      <a href="#" class="text-grey-800 hover:text-brand-700 dark:text-[#D4D4D4] dark:hover:text-brand-600 transition-colors" aria-label="Instagram">
        <svg class="w-[35px] h-[35px]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <!-- Twitter/X -->
      <a href="#" class="text-grey-800 hover:text-brand-700 dark:text-[#D4D4D4] dark:hover:text-brand-600 transition-colors" aria-label="Twitter">
        <svg class="w-[35px] h-[35px]" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <!-- Pinterest -->
      <a href="#" class="text-grey-800 hover:text-brand-700 dark:text-[#D4D4D4] dark:hover:text-brand-600 transition-colors" aria-label="Pinterest">
        <svg class="w-[35px] h-[35px]" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641 0 12.017 0z"/></svg>
      </a>
      <!-- YouTube -->
      <a href="#" class="text-grey-800 hover:text-brand-700 dark:text-[#D4D4D4] dark:hover:text-brand-600 transition-colors" aria-label="YouTube">
        <svg class="w-[35px] h-[35px]" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-grey-400 dark:border-grey-700 py-[15px] px-[20px] text-center text-[1.6rem] font-medium text-grey-700 dark:text-[#D4D4D4]">
    &copy;{year} {SITE_NAME}.online
  </div>
</footer>
