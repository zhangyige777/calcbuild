---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with the CalcBuild team — questions, corrections, calculator suggestions, and feedback welcome.">
  <div class="max-w-3xl mx-auto px-[20px] sm:px-6 lg:px-8 py-12">
    <h1 class="text-[3.5rem] max-[480px]:text-[2.8rem] font-semibold text-[#444] dark:text-grey-100 mb-[20px]">Contact Us</h1>

    <div class="space-y-[20px] text-[1.8rem] text-grey-700 dark:text-grey-300 leading-[1.55]">
      <p>
        Have a question, correction, or suggestion for a new calculator? We'd love to hear from you.
      </p>

      <h2 class="text-[3.0rem] max-[480px]:text-[2.6rem] font-semibold text-[#444] dark:text-grey-100 border-b-2 border-grey-300 dark:border-grey-700 pb-[10px] mb-[10px] mt-[30px]">What We Can Help With</h2>
      <ul class="space-y-[8px] list-disc pl-[25px]">
        <li><strong>Calculator suggestions</strong> — tell us what tools you'd like to see added</li>
        <li><strong>Error reports</strong> — if a calculation looks wrong, let us know so we can fix it</li>
        <li><strong>Formula questions</strong> — ask about the math behind any calculator</li>
        <li><strong>General feedback</strong> — we read every message and use it to improve</li>
      </ul>

      <h2 class="text-[3.0rem] max-[480px]:text-[2.6rem] font-semibold text-[#444] dark:text-grey-100 border-b-2 border-grey-300 dark:border-grey-700 pb-[10px] mb-[10px] mt-[30px]">Get in Touch</h2>
      <div class="p-[20px] bg-grey-200 dark:bg-grey-850 border border-grey-400 dark:border-grey-700 rounded-ic-md">
        <div class="flex items-center gap-[12px]">
          <svg class="w-[24px] h-[24px] text-brand-700 dark:text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          <span>Email: <a href="mailto:contact@calcbuild.online" class="text-brand-700 dark:text-brand-600 hover:text-brand-800 dark:hover:text-brand-500 font-medium">contact@calcbuild.online</a></span>
        </div>
      </div>

      <p class="text-[1.6rem] text-grey-500 dark:text-grey-400 mt-[20px]">
        We typically respond within 1–2 business days. For urgent corrections (wrong formulas, broken calculators), we prioritize same-day fixes.
      </p>
    </div>
  </div>
</BaseLayout>
