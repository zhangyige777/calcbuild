{
  "name": "calcbuild",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node -e \"const fs=require('fs'),p=require('path');const s=p.join('dist','sitemap-index.xml'),d=p.join('dist','sitemap.xml');if(fs.existsSync(s)){fs.copyFileSync(s,d);console.log('✔ Copied sitemap-index.xml → sitemap.xml')}\"",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^5.1.5",
    "astro": "^6.3.3",
    "js-yaml": "^4.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "puppeteer": "^24.43.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
